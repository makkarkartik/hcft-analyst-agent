# Copy to .env and fill in. Nothing here is required for M0 (pure-Python graphs).
FIREWORKS_API_KEY=
PINECONE_API_KEY=

# Data layer (defaults match docker-compose.yml)
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=hcft
PINECONE_INDEX=hcft

# Reader slot (M7 swap: point these at local Ollama, e.g. http://127.0.0.1:11434/v1)
READER_BASE_URL=
READER_MODEL=
READER_API_KEY=
